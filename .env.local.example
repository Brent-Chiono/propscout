# Google Maps API Key
# Used server-side for geocoding and client-side for the map
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Polk County Sheriff Sale Viewer base URL (no trailing slash)
SHERIFF_BASE_URL=https://sheriffsaleviewer.polkcountyiowa.gov

# Polk County Tax Search base URL (no trailing slash)
TAX_SEARCH_BASE_URL=https://taxsearch.polkcountyiowa.gov

# Antiforgery cookie for sheriff site (refresh this if requests start failing)
SHERIFF_COOKIE=.AspNetCore.Antiforgery.9r3Ldye5ReY=your_cookie_value_here


SETTINGS_ENCRYPTION_KEY